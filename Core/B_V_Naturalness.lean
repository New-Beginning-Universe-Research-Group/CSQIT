def EffectiveFin7Regular (M : Type*) [BoundedCausalLattice M] [Fintype M] : Prop :=
  let k_in : ℝ := 1
  let k_out : ℝ := 1 + seventh_root_real_part 1
  (internalAverageOutDegree M = k_out) ∧
  (twoAspectParameter (M := M) = k_in / (k_in + k_out))

