  let k_in : ℝ := 1
  let k_out : ℝ := 1 + seventh_root_real_part 1
  (∀ (x : M), x ≠ (⊥ : M) → x ≠ (⊤ : M) →
    (Set.ncard {y : M | isImmediateSuccessor x y} : ℝ) = k_out) ∧
  (twoAspectParameter (M := M) = k_in / (k_in + k_out))

